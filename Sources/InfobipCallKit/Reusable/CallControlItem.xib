<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="22154" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="22131"/>
        <capability name="System colors in document resources" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="CallControlItem" customModule="InfobipCallKit" customModuleProvider="target">
            <connections>
                <outlet property="captionLabel" destination="cap" id="conn-cap"/>
                <outlet property="contentView" destination="root" id="conn-root"/>
                <outlet property="iconContainer" destination="iconC" id="conn-iconc"/>
                <outlet property="iconView" destination="icon" id="conn-icon"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="root">
            <rect key="frame" x="0.0" y="0.0" width="72" height="79"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
            <subviews>
                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="iconC">
                    <rect key="frame" x="9" y="0.0" width="54" height="54"/>
                    <subviews>
                        <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" translatesAutoresizingMaskIntoConstraints="NO" id="icon">
                            <rect key="frame" x="15" y="15" width="24" height="24"/>
                            <constraints>
                                <constraint firstAttribute="width" constant="24" id="icon-w"/>
                                <constraint firstAttribute="height" constant="24" id="icon-h"/>
                            </constraints>
                        </imageView>
                    </subviews>
                    <color key="backgroundColor" systemColor="secondarySystemBackgroundColor"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="54" id="ic-w"/>
                        <constraint firstAttribute="height" constant="54" id="ic-h"/>
                        <constraint firstItem="icon" firstAttribute="centerX" secondItem="iconC" secondAttribute="centerX" id="ic-cx"/>
                        <constraint firstItem="icon" firstAttribute="centerY" secondItem="iconC" secondAttribute="centerY" id="ic-cy"/>
                    </constraints>
                </view>
                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Caption" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="cap">
                    <rect key="frame" x="0.0" y="60" width="72" height="15"/>
                    <fontDescription key="fontDescription" type="system" pointSize="12"/>
                    <color key="textColor" systemColor="secondaryLabelColor"/>
                    <nil key="highlightedColor"/>
                </label>
            </subviews>
            <constraints>
                <constraint firstAttribute="width" constant="72" id="root-w"/>
                <constraint firstItem="iconC" firstAttribute="top" secondItem="root" secondAttribute="top" id="c-top"/>
                <constraint firstItem="iconC" firstAttribute="centerX" secondItem="root" secondAttribute="centerX" id="c-cx"/>
                <constraint firstItem="cap" firstAttribute="top" secondItem="iconC" secondAttribute="bottom" constant="6" id="c-captop"/>
                <constraint firstItem="cap" firstAttribute="leading" secondItem="root" secondAttribute="leading" id="c-caplead"/>
                <constraint firstAttribute="trailing" secondItem="cap" secondAttribute="trailing" id="c-captrail"/>
                <constraint firstAttribute="bottom" secondItem="cap" secondAttribute="bottom" id="c-capbot"/>
            </constraints>
        </view>
    </objects>
</document>
