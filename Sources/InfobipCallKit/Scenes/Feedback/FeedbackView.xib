<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="22154" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="22131"/>
        <capability name="System colors in document resources" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="FeedbackView" customModule="InfobipCallKit" customModuleProvider="target">
            <connections>
                <outlet property="contentView" destination="root" id="c-root"/>
                <outlet property="emoji1" destination="e1" id="c-e1"/>
                <outlet property="emoji2" destination="e2" id="c-e2"/>
                <outlet property="emoji3" destination="e3" id="c-e3"/>
                <outlet property="skipButton" destination="skip" id="c-skip"/>
                <outlet property="submitButton" destination="submit" id="c-submit"/>
                <outlet property="titleLabel" destination="title" id="c-title"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="root">
            <rect key="frame" x="0.0" y="0.0" width="335" height="248"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
            <subviews>
                <stackView opaque="NO" contentMode="scaleToFill" axis="vertical" spacing="16" translatesAutoresizingMaskIntoConstraints="NO" id="vstack">
                    <rect key="frame" x="20" y="24" width="295" height="200"/>
                    <subviews>
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Cuộc gọi vừa rồi thế nào?" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="title">
                            <rect key="frame" x="0.0" y="0.0" width="295" height="22"/>
                            <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="17"/>
                            <nil key="textColor"/>
                            <nil key="highlightedColor"/>
                        </label>
                        <stackView opaque="NO" contentMode="scaleToFill" axis="horizontal" distribution="fillEqually" spacing="12" translatesAutoresizingMaskIntoConstraints="NO" id="emojiStack">
                            <rect key="frame" x="0.0" y="38" width="295" height="60"/>
                            <subviews>
                                <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="e1">
                                    <rect key="frame" x="0.0" y="0.0" width="90" height="60"/>
                                    <state key="normal" title="🙂"/>
                                </button>
                                <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="e2">
                                    <rect key="frame" x="102" y="0.0" width="90" height="60"/>
                                    <state key="normal" title="🙂"/>
                                </button>
                                <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="e3">
                                    <rect key="frame" x="205" y="0.0" width="90" height="60"/>
                                    <state key="normal" title="🙂"/>
                                </button>
                            </subviews>
                            <constraints>
                                <constraint firstAttribute="height" constant="60" id="emoji-h"/>
                            </constraints>
                        </stackView>
                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="submit" customClass="CallOptionButton" customModule="InfobipCallKit" customModuleProvider="target">
                            <rect key="frame" x="0.0" y="114" width="295" height="52"/>
                            <state key="normal" title="Gửi đánh giá"/>
                        </button>
                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="skip" customClass="CallOptionButton" customModule="InfobipCallKit" customModuleProvider="target">
                            <rect key="frame" x="0.0" y="178" width="295" height="52"/>
                            <state key="normal" title="Bỏ qua"/>
                        </button>
                    </subviews>
                </stackView>
            </subviews>
            <constraints>
                <constraint firstItem="vstack" firstAttribute="top" secondItem="root" secondAttribute="top" constant="24" id="v-top"/>
                <constraint firstItem="vstack" firstAttribute="leading" secondItem="root" secondAttribute="leading" constant="20" id="v-lead"/>
                <constraint firstAttribute="trailing" secondItem="vstack" secondAttribute="trailing" constant="20" id="v-trail"/>
                <constraint firstAttribute="bottom" secondItem="vstack" secondAttribute="bottom" constant="20" id="v-bot"/>
            </constraints>
        </view>
    </objects>
</document>
