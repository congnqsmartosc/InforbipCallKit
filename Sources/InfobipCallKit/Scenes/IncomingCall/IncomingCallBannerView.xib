<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="22154" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="22131"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="IncomingCallBannerView" customModule="InfobipCallKit" customModuleProvider="target">
            <connections>
                <outlet property="acceptButton" destination="accept" id="conn-accept"/>
                <outlet property="appLabel" destination="app" id="conn-app"/>
                <outlet property="contentView" destination="root" id="conn-root"/>
                <outlet property="declineButton" destination="decline" id="conn-decline"/>
                <outlet property="iconView" destination="icon" id="conn-icon"/>
                <outlet property="nameLabel" destination="name" id="conn-name"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="root">
            <rect key="frame" x="0.0" y="0.0" width="360" height="64"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
            <subviews>
                <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" translatesAutoresizingMaskIntoConstraints="NO" id="icon">
                    <rect key="frame" x="12" y="14" width="36" height="36"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="36" id="icon-w"/>
                        <constraint firstAttribute="height" constant="36" id="icon-h"/>
                    </constraints>
                </imageView>
                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Xanh SM" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="app">
                    <rect key="frame" x="58" y="12" width="100" height="15"/>
                    <fontDescription key="fontDescription" type="system" pointSize="12"/>
                    <nil key="textColor"/>
                    <nil key="highlightedColor"/>
                </label>
                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Nguyễn Văn Nam" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="name">
                    <rect key="frame" x="58" y="29" width="140" height="20"/>
                    <fontDescription key="fontDescription" type="system" pointSize="16"/>
                    <nil key="textColor"/>
                    <nil key="highlightedColor"/>
                </label>
                <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="decline" customClass="CircleIconButton" customModule="InfobipCallKit" customModuleProvider="target">
                    <rect key="frame" x="256" y="12" width="40" height="40"/>
                </button>
                <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="accept" customClass="CircleIconButton" customModule="InfobipCallKit" customModuleProvider="target">
                    <rect key="frame" x="308" y="12" width="40" height="40"/>
                </button>
            </subviews>
            <constraints>
                <constraint firstItem="icon" firstAttribute="leading" secondItem="root" secondAttribute="leading" constant="12" id="b-icon-lead"/>
                <constraint firstItem="icon" firstAttribute="centerY" secondItem="root" secondAttribute="centerY" id="b-icon-cy"/>

                <constraint firstItem="app" firstAttribute="leading" secondItem="icon" secondAttribute="trailing" constant="10" id="b-app-lead"/>
                <constraint firstItem="app" firstAttribute="top" secondItem="root" secondAttribute="top" constant="12" id="b-app-top"/>
                <constraint firstItem="decline" firstAttribute="leading" relation="greaterThanOrEqual" secondItem="app" secondAttribute="trailing" constant="10" id="b-app-trail"/>

                <constraint firstItem="name" firstAttribute="leading" secondItem="icon" secondAttribute="trailing" constant="10" id="b-name-lead"/>
                <constraint firstItem="name" firstAttribute="top" secondItem="app" secondAttribute="bottom" constant="2" id="b-name-top"/>
                <constraint firstAttribute="bottom" secondItem="name" secondAttribute="bottom" constant="12" id="b-name-bot"/>
                <constraint firstItem="decline" firstAttribute="leading" relation="greaterThanOrEqual" secondItem="name" secondAttribute="trailing" constant="10" id="b-name-trail"/>

                <constraint firstItem="decline" firstAttribute="centerY" secondItem="root" secondAttribute="centerY" id="b-decline-cy"/>
                <constraint firstItem="accept" firstAttribute="leading" secondItem="decline" secondAttribute="trailing" constant="10" id="b-gap"/>
                <constraint firstItem="accept" firstAttribute="centerY" secondItem="root" secondAttribute="centerY" id="b-accept-cy"/>
                <constraint firstAttribute="trailing" secondItem="accept" secondAttribute="trailing" constant="12" id="b-accept-trail"/>
            </constraints>
        </view>
    </objects>
</document>
